FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install patchpal - force latest version
RUN pip install --no-cache-dir --upgrade patchpal

# Set working directory
WORKDIR /workspace

# Use bash as entrypoint so sandbox script can pass commands
ENTRYPOINT ["/bin/bash", "-c"]

# Default to patchpal help if no command provided
CMD ["patchpal --help"]
