FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install patchpal (force rebuild: 2026-03-19)
RUN pip install --no-cache-dir patchpal

# Set working directory
WORKDIR /workspace

# Use bash as entrypoint so sandbox script can pass commands
ENTRYPOINT ["/bin/bash", "-c"]

# Default to patchpal help if no command provided
CMD ["patchpal --help"]
