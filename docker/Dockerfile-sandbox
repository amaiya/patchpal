FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install patchpal
RUN pip install --no-cache-dir patchpal

# Set working directory
WORKDIR /workspace

# Default command (can be overridden)
CMD ["patchpal", "--help"]
